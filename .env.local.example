# ─── Stripe (Donation checkout + donor analytics + dashboard POS/Terminal) ──
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# Publishable key — required for the dashboard Terminal (in-person card payments)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ─── Telnyx (SMS + Calls + Softphone) ────────────────────────────────────────
# API key from telnyx.com → API Keys
TELNYX_API_KEY=KEY...
# Your Telnyx phone number in E.164 format
TELNYX_PHONE_NUMBER=+15514009427
NEXT_PUBLIC_TELNYX_PHONE_NUMBER=+15514009427
# Webhook URL to set in Telnyx portal: https://indiancaucus.org/api/telnyx/webhook
# SIP credentials for browser softphone (Telnyx → SIP Connections → Credentials)
NEXT_PUBLIC_TELNYX_SIP_USERNAME=
NEXT_PUBLIC_TELNYX_SIP_PASSWORD=
# Telephony Credential ID for token-based WebRTC auth (Telnyx → Auth → Telephony Credentials)
TELNYX_WEBRTC_CREDENTIAL_ID=
NEXT_PUBLIC_TELNYX_WEBRTC_CREDENTIAL_ID=

# ─── PostHog (Behavior analytics) ───────────────────────────────────────────
# Sign up free at posthog.com → Project Settings → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─── Web Push (iOS 16.4+ home-screen PWA notifications) ──────────────────────
# Generate a keypair: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact URI required by the Web Push spec
VAPID_SUBJECT=mailto:admin@indiancaucus.org

# ─── Cron jobs ───────────────────────────────────────────────────────────────
# Secret used to authenticate Vercel cron calls — generate: openssl rand -base64 32
CRON_SECRET=

# Public base URL used for Stripe success/cancel redirects
NEXT_PUBLIC_BASE_URL=https://www.indiancaucusofsecaucus.org

# ─── Vercel Postgres (Subscriber database) ──────────────────────────────────
# Add a Postgres database in your Vercel project dashboard, then copy the
# connection strings here. Vercel sets these automatically in deployed envs.
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# ─── Resend (Email delivery) ─────────────────────────────────────────────────
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_...
# The "from" address for newsletters and welcome emails.
# The domain must be verified in Resend → Domains.
# Sender addresses — all domains must be verified in Resend
# Newsletter / welcome emails
EMAIL_FROM_NEWSLETTER=Indian Caucus of Secaucus <noreply@newsletters.indiancaucus.org>
# Donation receipts and giving-related emails
EMAIL_FROM_DONATIONS=Indian Caucus of Secaucus <noreply@indiancaucus.org>
# Event announcements and campaigns
EMAIL_FROM_EVENTS=Indian Caucus of Secaucus <noreply@newsletters.indiancaucus.org>
# Legacy fallback (used if specific ones above are not set)
EMAIL_FROM=Indian Caucus of Secaucus <noreply@newsletters.indiancaucus.org>
# Resend Audience / Segment ID — found in Resend → Audiences → Segments
RESEND_AUDIENCE_ID=
# Where contact form messages are forwarded (optional)
CONTACT_NOTIFY_EMAIL=indiancaucusofsecaucus@gmail.com

# ─── NextAuth (Dashboard authentication) ────────────────────────────────────
# Generate a random secret: openssl rand -base64 32
NEXTAUTH_SECRET=
# Your deployed URL (or http://localhost:3000 for local dev)
NEXTAUTH_URL=https://www.indiancaucusofsecaucus.org

# Fallback admin password for /dashboard/login
ADMIN_PASSWORD=

# ─── Microsoft O365 / Azure AD (optional SSO for dashboard) ─────────────────
# 1. Go to https://portal.azure.com → Azure Active Directory → App registrations
# 2. New registration → name it "Indian Caucus Dashboard"
# 3. Redirect URI: https://yoursite.com/api/auth/callback/azure-ad
# 4. Under Certificates & Secrets, create a new client secret
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=
# Optional: restrict login to this email domain (e.g. indiancaucusofsecaucus.org)
AZURE_AD_ALLOWED_DOMAIN=

# ─── Freshdesk (Contact form tickets) ───────────────────────────────────────
# API key from Freshdesk → Profile Settings → Your API Key
FRESHDESK_API_KEY=
# Your subdomain only, e.g. "yourcompany" for yourcompany.freshdesk.com
FRESHDESK_DOMAIN=yourcompany.freshdesk.com

# ─── Social media links (optional) ─────────────────────────────────────────
NEXT_PUBLIC_FACEBOOK=https://www.facebook.com/IndianCaucusSEC
NEXT_PUBLIC_INSTAGRAM=https://www.instagram.com/indiancaucussec
NEXT_PUBLIC_YOUTUBE=
NEXT_PUBLIC_TIKTOK=

# ─── RSVP form link (optional) ──────────────────────────────────────────────
# If set, the "RSVP / Volunteer" button on the events page links here
NEXT_PUBLIC_RSVP_FORM=
